# ─────────────────────────────────────────────────────────────
# Pricing Monitor — environment configuration (config.py가 흡수)
# 이 파일을 .env 로 복사한 뒤 값을 채우세요.
# ─────────────────────────────────────────────────────────────

# Claude API (구조화 추출)
ANTHROPIC_API_KEY=sk-ant-...

# 추출 모델
ANTHROPIC_MODEL=claude-sonnet-4-6

# SQLite 경로
#   Render: /var/data/pricing.db  (Persistent Disk)
#   로컬:   ./data/pricing.db
DB_PATH=./data/pricing.db

# 스케줄 방식
#   internal = 웹 프로세스 내 APScheduler (Render 상시)
#   external = OS 스케줄러 → CLI (로컬 PC)
SCHEDULER_MODE=external

# 주간 수집 시각 (internal 모드에서만 사용, ET 기준)
SCHEDULE_DAY_OF_WEEK=mon
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0
SCHEDULE_TIMEZONE=America/New_York

# US 로케일 강제 (8장)
LOCALE=en-US
TIMEZONE_ID=America/New_York
ACCEPT_LANGUAGE=en-US,en;q=0.9

# 웹 서버 포트
PORT=8000

# companies 입력 파일
COMPANIES_FILE=./companies.yaml

# Playwright fetch 동작
FETCH_TIMEOUT_MS=45000
FETCH_MAX_RETRIES=3
